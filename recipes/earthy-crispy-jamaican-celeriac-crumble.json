{
  "title": "Earthy Crispy Jamaican Celeriac Crumble",
  "description": "This indulgent dish features celeriac in an earthy and crispy crumble topping, perfect for breakfast or dessert.",
  "cuisine": "Jamaican",
  "diet": null,
  "meal": "dessert",
  "ingredients": [
    {
      "name": "celeriac",
      "amount": "1 medium bulb",
      "notes": "peeled and thinly sliced"
    },
    {
      "name": "eggs",
      "amount": "2 large",
      "notes": "lightly beaten"
    },
    {
      "name": "flour",
      "amount": "3 tablespoons",
      "notes": "all-purpose or gluten-free as needed"
    },
    {
      "name": "brown sugar",
      "amount": "1/4 cup",
      "notes": "packed for best texture"
    },
    {
      "name": "salt",
      "amount": "a pinch",
      "notes": "to taste"
    },
    {
      "name": "milk",
      "amount": "2 tablespoons",
      "notes": "full-fat or alternative as needed"
    },
    {
      "name": "butter",
      "amount": "8 tablespoons",
      "notes": "cold, cut into small pieces"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C). Grease a baking dish.",
    "Mix celeriac, eggs, flour, brown sugar, salt, and milk in a large bowl until combined.",
    "Stir in cold butter pieces until mixture is crumbly.",
    "Pour the mixture into the prepared baking dish.",
    "Bake for 30-45 minutes or until top crust is golden brown.",
    "Cool before serving. Can be served warm as dessert or with a scoop of vanilla ice cream."
  ],

      "name": "water chestnuts",
      "amount": "1 1/2 cups",
      "notes": "canned, drained, and rinsed"
    },
    {
      "name": "oat flour",
      "amount": "1 cup"
    },
    {
      "name": "brown sugar",
      "amount": "1/2 cup"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "namul",
      "amount": "1/4 cup",
      "notes": "blanched and seasoned"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, mix together the oat flour, brown sugar, and salt.",
    "Add the coconut oil, lemon juice, and vanilla extract to the bowl and stir until crumbly.",
    "In a separate bowl, mix together the water chestnuts and namul.",
    "Add the water chestnut mixture to the crumb mixture and stir until combined.",
    "Transfer the mixture to a baking dish and bake for 35 minutes.",
    "Remove the crumble from the oven and let it cool for a few minutes.",
    "Serve the crumble warm, garnished with additional namul if desired."
  ],

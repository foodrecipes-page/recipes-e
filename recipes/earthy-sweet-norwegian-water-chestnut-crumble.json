  "title": "Earthy Sweet Norwegian Water Chestnut Crumble",
  "description": "A sweet and crumbly Norwegian dish featuring water chestnut, perfect for a cozy dessert, dairy-free friendly.",
  "cuisine": "Norwegian",
  "diet": [
    "dairy-free",
    "vegetarian"
  ],

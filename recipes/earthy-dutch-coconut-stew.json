{
  "title": "Earthy Dutch Coconut Stew",
  "description": "A nostalgic Dutch stew featuring rich unsweetened coconut milk, earthy flavors, and Mediterranean-friendly ingredients. Perfect for a cozy, comforting meal.",
  "cuisine": "dutch",
  "diet": [
    "vegetarian",
    "mediterranean"

      "name": "onion",
      "amount": "1 medium",
      "notes": "finely diced"
    },
    {
      "name": "carrot",
      "amount": "150g",
      "notes": "diced into 1cm cubes"
    },
    {
      "name": "celery",
      "amount": "100g",
      "notes": "diced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "dutch tomato paste",
      "amount": "15ml",
      "notes": "for depth of flavor"
    },
    {
      "name": "dried oregano",
      "amount": "1 tsp",
      "notes": "freshly ground for best results"
    },
    {
      "name": "thyme",
      "amount": "1/2 tsp",
      "notes": "dried"
    },
    {

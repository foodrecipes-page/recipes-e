      "amount": "1",
      "notes": "remove before serving"
    },
    {
      "name": "chicken broth",
      "amount": "300ml",
      "notes": "low-sodium for Mediterranean diet"
    },
    {
      "name": "olive oil",
      "amount": "20ml",
      "notes": "for sautéing"
    },
    {
      "name": "salt",
      "amount": "to taste",
      "notes": "use sea salt for better flavor"
    }
  ],
  "instructions": [
    "Heat olive oil in a medium pot over medium heat",
    "Add onions, carrots, and celery; sauté for 5 minutes until softened",
    "Add garlic, tomato paste, oregano, thyme, and bay leaf; cook for 2 minutes",
    "Pour in coconut milk and chicken broth; bring to a gentle boil",
    "Reduce heat to low, cover, and simmer for 20 minutes until vegetables are tender",
    "Season with salt to taste; remove bay leaf before serving"
  ],

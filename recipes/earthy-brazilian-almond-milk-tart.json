{
  "title": "Earthy Brazilian Almond Milk Tart",
  "description": "A crowd-pleasing Brazilian dessert featuring flaky pastry, earthy flavors, and almond milk.",
  "cuisine": "Brazilian",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],

{
  "title": "Elegant Malaysian Snap Peas Curry",
  "description": "A creamy, aromatic curry that pairs sweet snap peas with fragrant Malaysian spices for a romantic date night meal.",
  "cuisine": "malaysian",
  "diet": [
    "diabetic-friendly"
  ],
  "meal": "dinner",

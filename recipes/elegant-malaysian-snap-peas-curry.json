      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "fresh cilantro",
      "amount": "to garnish"
    }
  ],
  "instructions": [
    "Heat coconut oil in a large skillet over medium heat.",
    "Add diced onion and sauté until translucent, about 3 minutes.",
    "Stir in minced garlic and ginger and cook for 1 minute until fragrant.",
    "Add red curry paste and stir to coat the aromatics for 30 seconds.",
    "Pour in unsweetened coconut milk and bring to a gentle simmer.",
    "Add cherry tomatoes and tamarind paste, then simmer for 5 minutes until tomatoes soften.",
    "Toss in sugar snap peas and cook for 4-5 minutes until they are tender yet crisp.",
    "Stir in date syrup and lime juice, season with salt to taste, and simmer for an additional minute.",
    "Remove from heat, garnish with fresh cilantro, and serve hot with steamed brown rice or cauliflower rice."
  ],

      "amount": "3 cloves",
      "notes": "Halal-certified garlic"
    },
    {
      "name": "Carrots",
      "amount": "2 medium",
      "notes": "Roasted for flavor"
    },
    {
      "name": "Julienned Bell Peppers",
      "amount": "1 large",
      "notes": "To add color and crunch"
    },
    {
      "name": "Fresh Herbs",

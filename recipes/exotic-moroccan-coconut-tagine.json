      "name": "coconut cream",
      "amount": "1 can",
      "notes": "full fat"
    },
    {
      "name": "meringue nests",
      "amount": "12 pieces"
    },
    {
      "name": "tagine spice mix",
      "amount": "2 tablespoons"
    },
    {
      "name": "chickpeas",
      "amount": "1 can"
    },
    {
      "name": "diced apricots",
      "amount": "1 cup"
    },
    {
      "name": "pistachios",
      "amount": "1/2 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, mix together the tagine spice mix, chickpeas, diced apricots, pistachios, salt, and black pepper.",
    "In a separate bowl, whip the coconut cream until it forms stiff peaks.",
    "Fold the whipped coconut cream into the chickpea mixture until well combined.",
    "Spoon the mixture into a molcajete vessel, creating a nest shape in the center of each serving.",
    "Place a meringue nest in the center of each serving.",
    "Drizzle the olive oil over the top of each serving.",
    "Bake for 25 minutes, or until the meringue is golden brown."
  ],

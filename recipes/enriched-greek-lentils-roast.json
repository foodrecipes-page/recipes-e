      "notes": "soak 30 min, drain"
    },
    {
      "name": "Olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "White wine (dry)",
      "amount": "1 cup"
    },
    {
      "name": "Onion, diced",
      "amount": "1 medium"
    },
    {

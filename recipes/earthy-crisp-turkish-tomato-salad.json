{
  "title": "Earthy Crisp Turkish Tomato Salad",
  "description": "A quick, lowfat Turkish salad featuring earthy tomato puree, crisp cucumber, fresh tomatoes, and a lemonyogurtherb dressing.",
  "cuisine": "Turkish",
  "diet": [
    "low-fat",
    "vegetarian"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "Tomato puree",
      "amount": "200 g",
      "notes": "Low-sodium if possible"
    },
    {
      "name": "Fresh tomatoes",
      "amount": "2 medium (\u2248200 g)",
      "notes": "Chopped into bite\u2011sized cubes"
    },
    {
      "name": "Cucumber",
      "amount": "1 small (\u2248120 g)",
      "notes": "Deseeded and sliced thinly"
    },
    {
      "name": "Red onion",
      "amount": "1/4 medium (\u224830 g)",
      "notes": "Finely minced"
    },
    {
      "name": "Fresh parsley",
      "amount": "15 g",
      "notes": "Chopped"
    },
    {
      "name": "Fresh mint",
      "amount": "10 g",
      "notes": "Chopped"
    },
    {
      "name": "Low\u2011fat plain yogurt",
      "amount": "100 g",
      "notes": "Room temperature"
    },
    {
      "name": "Olive oil",
      "amount": "1 tsp (\u22485 ml)",
      "notes": "Extra\u2011virgin, cold\u2011pressed"
    },
    {
      "name": "Lemon juice",
      "amount": "1 tbsp (\u224815 ml)",
      "notes": "Freshly squeezed"
    },
    {
      "name": "Salt",
      "amount": "1/4 tsp",
      "notes": "To taste"
    },
    {
      "name": "Black pepper",
      "amount": "Pinch",
      "notes": "Freshly ground"
    }
  ],
  "instructions": [
    "1. In a medium bowl, whisk together the low\u2011fat yogurt, lemon juice, olive oil, salt, and pepper until smooth.",
    "2. Add the tomato puree to the dressing and stir until fully incorporated.",
    "3. Fold in the chopped tomatoes, sliced cucumber, minced red onion, parsley, and mint until everything is evenly coated.",
    "4. Taste and adjust seasoning if needed, adding more salt or lemon juice to taste.",
    "5. Cover and refrigerate for 5\u201310 minutes to allow flavors to meld before serving."
  ],

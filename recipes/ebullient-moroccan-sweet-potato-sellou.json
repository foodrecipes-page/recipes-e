  "instructions": [
    "Preheat oven to 180C.",
    "Spread diced sweet potatoes on a baking sheet and roast for 25 minutes until tender.",
    "Remove from oven and let cool slightly, then transfer to a food processor.",
    "Pulse until smooth, adding ground almonds, oat flour, honey, coconut oil, cinnamon, ginger, and sea salt.",
    "Pour mixture into a greased baking dish and smooth the top.",
    "Bake at 180C for 25 minutes until set and golden.",
    "Let cool for 5 minutes, then cut into squares.",
    "Serve warm or at room temperature."
  ],

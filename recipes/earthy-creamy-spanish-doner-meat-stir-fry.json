{
  "title": "Earthy Creamy Spanish Doner Meat Stir-fry",
  "description": "A paleo-friendly meal-prep dish featuring poached doner meat in an earthy, creamy sauce made with almond milk.",
  "cuisine": "Spanish",
  "diet": [
    "paleo"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken thighs",
      "amount": "4 pcs"
    },
    {
      "name": "almond milk",
      "amount": "1 cup"
    },
    {
      "name": "butter",
      "amount": "2 tbsp"
    },
    {
      "name": "garlic cloves",
      "amount": "6 pieces, minced"
    },
    {
      "name": "onion",
      "amount": "1 medium, finely chopped"
    },
    {
      "name": "parsley",
      "amount": "handful, chopped fresh"
    },
    {
      "name": "paprika",
      "amount": "pinch"
    },
    {
      "name": "black pepper",
      "amount": "dash"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C). Season chicken with paprika and black pepper.",
    "Cook chicken in a skillet over medium heat until golden brown on all sides. Remove from pan.",
    "In the same skillet, melt butter over low heat. Add garlic and onion; cook for about 2 minutes or until soft.",
    "Stir in almond milk, reduce to simmer. Simmer for 10-15 minutes or until thickened slightly.",
    "Return chicken to skillet with sauce. Gently stir in chopped parsley.",
    "Spoon mixture into a serving bowl and serve warm."
  ],

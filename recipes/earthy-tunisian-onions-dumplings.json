{
  "title": "Earthy Tunisian Onions Dumplings",
  "description": "Dense, earthy dumplings made with red onions and a simple Tunisian spice blend, perfect for weeknights. Kosher-friendly with no meat.",
  "cuisine": "tunisian",
  "diet": [
    "kosher",
    "vegetarian"
  ],

  "ingredients": [
    {
      "name": "red onion",
      "amount": "1 large",
      "notes": "thinly sliced"
    },
    {
      "name": "all-purpose flour",
      "amount": "150g",
      "notes": "for dough"
    },
    {
      "name": "kosher salt",
      "amount": "1 tsp",
      "notes": "for flavor"
    },
    {
      "name": "ground cumin",
      "amount": "1/2 tsp",
      "notes": "Tunisian spice blend"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": "for frying"
    }
  ],
  "instructions": [
    "Slice red onion thinly and set aside.",
    "In a bowl, mix flour, salt, cumin, and garlic until combined.",
    "Add onion and olive oil to the flour mixture, knead into a firm dough.",
    "Roll dough into small balls, then flatten slightly for cooking.",
    "Heat oil in a pan over medium heat, add dumplings, and fry until golden brown.",
    "Serve hot with a side of Tunisian-style yogurt or salad."
  ],

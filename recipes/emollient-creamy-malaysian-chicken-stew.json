{
  "title": "Emollient Creamy Malaysian Chicken Stew",
  "description": "A buttery, shaggy one‑pot Malaysian chicken stew thickened with full fat sour cream and seasoned with aromatic spices. It is slow‑simmered for a silky texture and Ayurvedic tamasic‑friendly profile.",
  "cuisine": "Malaysian",
  "diet": null,

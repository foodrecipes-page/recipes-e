{
  "title": "Earthy Savory Irish Lamb Stew",
  "description": "A hearty one-pot Irish dish featuring lamb, massaman paste, and mushimono steam, with a mustardy and shaggy texture, kosher friendly. This stew is perfect for a cold winter night.",
  "cuisine": "Irish",
  "diet": [
    "kosher"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 1/2 inch cubes"
    },
    {
      "name": "massaman paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "mustard",
      "amount": "1 teaspoon"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and sliced"
    },
    {
      "name": "potatoes",
      "amount": "2 large",
      "notes": "peeled and cubed"
    },
    {
      "name": "onions",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "beef broth",
      "amount": "2 cups"
    },
    {
      "name": "water",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Heat oil in a large pot over medium high heat.",
    "Add the lamb and cook until browned on all sides.",
    "Add the massaman paste, mustard, carrots, potatoes, onions, and garlic, and cook for 1 minute.",
    "Add the beef broth and water, and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 1 1/2 hours.",
    "Season with salt and pepper to taste.",
    "Serve hot, garnished with fresh parsley.",
    "Let it rest for 10 minutes before serving."
  ],

  "instructions": [
    "preheat oven to 375\u00000f.",
    "saute the mirepoix in olive oil until tender, about 5 minutes.",
    "add the garlic and cook for another minute.",
    "add the sun-dried tomatoes, cherry tomatoes, salt, and balsamic vinegar. cook for 2 minutes, stirring occasionally.",
    "transfer the mixture to a baking dish and top with gruy\u00167re cheese.",
    "bake for 15 minutes, or until the cheese is melted and bubbly.",
